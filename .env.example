# ---- RetailCare Orchestrator env template ----
# Copy to `.env` (project root) OR keep your real keys in `.claude/.env`.
# Both locations are git-ignored. NEVER commit real keys.

# DeepSeek (OpenAI-compatible). deepseek-v4-flash = weak/cheap, deepseek-v4-pro = strong.
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Model roles for cost/quality experiments (E6 Pareto)
RETAILCARE_MODEL_WEAK=deepseek-v4-flash
RETAILCARE_MODEL_STRONG=deepseek-v4-pro

# Reasoning model needs generous output budget (reasoning tokens are consumed first)
RETAILCARE_MAX_TOKENS=2048
RETAILCARE_TEMPERATURE=0.0

# Pricing (USD per 1M tokens) — UPDATE with real DeepSeek prices for accurate cost_per_task
RETAILCARE_PRICE_IN_PER_M=0.28
RETAILCARE_PRICE_OUT_PER_M=0.42

# Data layer: PostgreSQL in prod (docker compose), SQLite fallback for local/tests
DATABASE_URL=postgresql+psycopg2://retailcare:retailcare@localhost:5432/retailcare
# DATABASE_URL=sqlite:///./retailcare.db

# Chroma: embedded persistent dir (no Docker) OR server host:port (docker compose)
CHROMA_PERSIST_DIR=./.chroma
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
CHROMA_HOST_PORT=8001

# Demo/dev defaults seed mock orders on API startup. Set false for a persistent DB.
RETAILCARE_SEED_ON_STARTUP=true
